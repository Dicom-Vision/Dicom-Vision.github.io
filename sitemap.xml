---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {% assign pages = site.pages | where_exp: "p", "p.url != '/404.html'" %}
  {% for page in pages %}
  {% unless page.url contains 'assets/' or page.url contains 'feed' or page.url contains 'sitemap' or page.url contains 'robots' or page.url contains 'atlassian' or page.url contains 'DOCKER' or page.url contains 'MODERN' %}
  <url>
    <loc>{{ site.url }}{{ page.url | remove: 'index.html' }}</loc>
    <xhtml:link rel="alternate" hreflang="{{ site.lang | default: 'en' }}" href="{{ site.url }}{{ page.url | remove: 'index.html' }}" />
    <xhtml:link rel="alternate" hreflang="{% if site.lang == 'it' %}en{% else %}it{% endif %}" href="{{ site.alternate_url }}{{ page.url | remove: 'index.html' }}" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://dicom.vision{{ page.url | remove: 'index.html' }}" />
    {% if page.last_modified_at %}
    <lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
